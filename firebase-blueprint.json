{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and study progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "exam": { "type": "string", "enum": ["JEE", "NEET"] },
        "isSubscribed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "completedLectures": { "type": "array", "items": { "type": "string" } },
        "reminders": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["topic", "mock-test"] },
              "title": { "type": "string" },
              "scheduledFor": { "type": "string", "format": "date-time" },
              "isCompleted": { "type": "boolean" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["uid", "email", "exam", "isSubscribed"]
    },
    "Lecture": {
      "title": "Lecture",
      "description": "Educational video lecture",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string", "enum": ["Physics", "Chemistry", "Maths", "Biology"] },
        "topic": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Question": {
      "title": "Question",
      "description": "Study question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "number" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "explanation": { "type": "string" },
        "type": { "type": "string", "enum": ["MCQ", "Numerical"] }
      }
    },
    "Performance": {
      "title": "Performance",
      "description": "User performance tracking for spaced repetition",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "lastAttempted": { "type": "string", "format": "date-time" },
        "nextReview": { "type": "string", "format": "date-time" },
        "interval": { "type": "number" },
        "easeFactor": { "type": "number" },
        "correctCount": { "type": "number" },
        "wrongCount": { "type": "number" }
      }
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A set of questions for practice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "QuizAttempt": {
      "title": "QuizAttempt",
      "description": "User's attempt at a quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Course": {
      "title": "Course",
      "description": "A structured learning path",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "lectureIds": { "type": "array", "items": { "type": "string" } },
        "quizIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MockTest": {
      "title": "MockTest",
      "description": "A full-length mock exam",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "exam": { "type": "string", "enum": ["JEE", "NEET"] },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "durationMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MockTestAttempt": {
      "title": "MockTestAttempt",
      "description": "User's attempt at a mock test",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockTestId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "subjectScores": { "type": "object" },
        "completedAt": { "type": "string", "format": "date-time" },
        "timeTakenSeconds": { "type": "number" }
      }
    },
    "StudyGroup": {
      "title": "StudyGroup",
      "description": "A small group of students for collaborative study",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "maxMembers": { "type": "number" },
        "isPrivate": { "type": "boolean" },
        "inviteCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "exam": { "type": "string", "enum": ["JEE", "NEET"] }
      },
      "required": ["id", "name", "creatorId", "memberIds", "maxMembers", "isPrivate", "exam"]
    },
    "GroupMessage": {
      "title": "GroupMessage",
      "description": "A message sent within a study group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "doubt", "system"] },
        "resolved": { "type": "boolean" }
      },
      "required": ["id", "groupId", "senderId", "text", "createdAt", "type"]
    },
    "GroupNote": {
      "title": "GroupNote",
      "description": "A note shared within a study group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "title", "content", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/lectures/{lectureId}": {
      "schema": "Lecture",
      "description": "Video lectures"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Question bank"
    },
    "/performance/{perfId}": {
      "schema": "Performance",
      "description": "Spaced repetition data"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Practice quizzes"
    },
    "/quizAttempts/{attemptId}": {
      "schema": "QuizAttempt",
      "description": "User quiz attempts"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Structured courses"
    },
    "/mockTests/{testId}": {
      "schema": "MockTest",
      "description": "Full-length mock tests"
    },
    "/mockTestAttempts/{attemptId}": {
      "schema": "MockTestAttempt",
      "description": "User mock test attempts"
    },
    "/studyGroups/{groupId}": {
      "schema": "StudyGroup",
      "description": "Study groups"
    },
    "/studyGroups/{groupId}/messages/{messageId}": {
      "schema": "GroupMessage",
      "description": "Messages within a study group"
    },
    "/studyGroups/{groupId}/notes/{noteId}": {
      "schema": "GroupNote",
      "description": "Notes shared within a study group"
    }
  }
}
